{
  "name": "example-typeorm",
  "version": "0.0.1",
  "private": true,
  "description": "Example consumer of @luisjrez/nestjs-keycloak-auth using TypeORM + SQLite",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main",
    "test": "jest --passWithNoTests",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "lint": "echo 'lint ok'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo *.sqlite"
  },
  "dependencies": {
    "@luisjrez/nestjs-keycloak-auth": "workspace:*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/typeorm": "^10.0.2",
    "better-sqlite3": "^11.3.0",
    "cookie-parser": "^1.4.6",
    "helmet": "^8.2.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.3.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cookie-parser": "^1.4.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/speakeasy": "^2.0.0",
    "@types/supertest": "^6.0.0",
    "jest": "^29.7.0",
    "speakeasy": "^2.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  },
  "jest": {
    "displayName": "example-typeorm",
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "tsconfig": "tsconfig.json" }]
    },
    "testEnvironment": "node"
  }
}
