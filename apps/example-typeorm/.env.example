# ─── Auth (Keycloak) ─────────────────────────────────
KEYCLOAK_CONFIG_PATH=../../docker/keycloak/keycloak-realm.json
KEYCLOAK_SERVER_URL=http://localhost:8080

# ─── JWT (must be >= 32 chars and distinct; change in production!) ───
ACCESS_TOKEN_SECRET=dev-only-access-token-secret-32-chars!!
REFRESH_TOKEN_SECRET=dev-only-refresh-token-secret-32-chars!

# ─── SMTP / Email (Mailpit) ──────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM=noreply@example.com

# ─── SQLite token store (no Docker needed) ───────────
SQLITE_PATH=auth-typeorm.sqlite

# ─── App ──────────────────────────────────────────────
APP_URL=http://localhost:3001
PORT=3001
NODE_ENV=development
