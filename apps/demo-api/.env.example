# ─── Auth ─────────────────────────────────────────────
KEYCLOAK_CONFIG_PATH=./keycloak-realm.json
KEYCLOAK_SERVER_URL=http://localhost:8080

# ─── JWT (change in production!) ─────────────────────
ACCESS_TOKEN_SECRET=dev-access-secret-change-me
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-me

# ─── SMTP / Email ────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM=noreply@example.com

# ─── CORS ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Application ──────────────────────────────────────
APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/auth_demo
