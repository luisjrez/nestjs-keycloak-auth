{
  "moduleFileExtensions": ["js", "json", "ts", "tsx"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".+\\.e2e-spec\\.ts$",
  "testTimeout": 120000,
  "transform": {
    "^.+\\.(ts|tsx)$": [
      "ts-jest",
      {
        "tsconfig": "tsconfig.json",
        "diagnostics": true
      }
    ]
  }
}
