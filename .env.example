# ─── Keycloak ─────────────────────────────────────────
# These come from the realm JSON generated by `auth-cli init`
# or you can set them directly here:
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=my-app
KEYCLOAK_CLIENT_ID=my-app-api
KEYCLOAK_CLIENT_SECRET=change-me

# ─── JWT (signed locally by the package) ─────────────
ACCESS_TOKEN_SECRET=change-me-to-a-random-64-char-string
REFRESH_TOKEN_SECRET=change-me-to-a-different-random-64-char-string

# ─── Database (Demo API) ─────────────────────────────
DATABASE_URL=postgresql://keycloak:keycloak@localhost:5432/auth_demo

# ─── Email ───────────────────────────────────────────
EMAIL_FROM=noreply@example.com
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
