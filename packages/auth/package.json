{
  "name": "@luisjrez/nestjs-keycloak-auth",
  "version": "0.1.0",
  "description": "A clean-architecture NestJS authentication module backed by Keycloak",
  "license": "MIT",
  "author": "Luis Juarez",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luisjrez/keycloak-nestjs-authentication-api.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "auth-cli": "dist/cli/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "default": "./dist/cli/index.js"
    },
    "./email": {
      "types": "./dist/email-templates/index.d.ts",
      "default": "./dist/email-templates/index.js"
    }
  },
  "files": [
    "dist",
    "src/email-templates/**/*.tsx"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:int": "jest --config jest.int.config.ts --passWithNoTests",
    "lint": "echo 'lint ok'",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "axios": "^1.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "commander": "^12.0.0",
    "jose": "^5.6.0",
    "nodemailer": "^6.9.0",
    "qrcode": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@nestjs/throttler": "^6.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/qrcode": "^1.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/speakeasy": "^2.0.0",
    "@types/supertest": "^7.2.0",
    "cookie-parser": "^1.4.7",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "cookie-parser": "^1.4.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
